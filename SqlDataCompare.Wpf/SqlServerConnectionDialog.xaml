<Window x:Class="SqlDataCompare.Wpf.SqlServerConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL Server connection"
        Height="480"
        Width="500"
        MinHeight="400"
        MinWidth="440"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#444" Margin="0,0,0,12">
            <Run>Similar to SQL Server Management Studio. Builds a connection string for Microsoft SQL Server only.</Run>
            <LineBreak/><LineBreak/>
            <Run FontStyle="Italic">If you see 'error occurred during login process (provider SSL...)', turn on Trust server certificate below (common for local SQL, Docker, or self-signed TLS), or ask your admin for a certificate that matches the server name.</Run>
        </TextBlock>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Server" VerticalAlignment="Center" Margin="0,4"/>
            <TextBox x:Name="ServerText" Grid.Row="0" Grid.Column="1" Margin="8,4,0,4"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Authentication" VerticalAlignment="Top" Margin="0,8,0,4"/>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,4,0,4">
                <RadioButton x:Name="AuthWindows" Content="Windows Authentication" GroupName="Auth" IsChecked="True" Margin="0,0,0,6"/>
                <RadioButton x:Name="AuthSql" Content="SQL Server Authentication" GroupName="Auth"/>
            </StackPanel>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="User name" VerticalAlignment="Center" Margin="0,4"/>
            <TextBox x:Name="UserText" Grid.Row="2" Grid.Column="1" Margin="8,4,0,4" IsEnabled="False"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Password" VerticalAlignment="Center" Margin="0,4"/>
            <PasswordBox x:Name="PasswordText" Grid.Row="3" Grid.Column="1" Margin="8,4,0,4" IsEnabled="False"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Database" VerticalAlignment="Center" Margin="0,4"/>
            <TextBox x:Name="DatabaseText" Grid.Row="4" Grid.Column="1" Margin="8,4,0,4"
                     ToolTip="Optional. Leave empty for server default catalog."/>

            <CheckBox x:Name="EncryptCheck" Grid.Row="5" Grid.Column="1" Content="Encrypt connection" IsChecked="True" Margin="8,8,0,4"
                      ToolTip="Recommended on. Uses TLS; requires a trusted server certificate unless Trust server certificate is on."/>
            <CheckBox x:Name="TrustCertCheck" Grid.Row="6" Grid.Column="1" Content="Trust server certificate" IsChecked="True" Margin="8,4,0,0"
                      ToolTip="Skip validating the SQL Server TLS certificate. Typical for local/dev servers; use a proper CA in production and turn this off."/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="OK" IsDefault="True" MinWidth="88" Margin="0,0,8,0" Padding="12,6" Click="Ok_Click"/>
            <Button Content="Cancel" IsCancel="True" MinWidth="88" Padding="12,6" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
