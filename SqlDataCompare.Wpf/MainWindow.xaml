<Window x:Class="SqlDataCompare.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SqlDataCompare.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="SQL Data Compare" Height="760" Width="1180" MinWidth="900" MinHeight="640"
        WindowStyle="None"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        d:DataContext="{d:DesignInstance local:MainViewModel, IsDesignTimeCreatable=False}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="5"
                            GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <DockPanel>

        <!-- ══════════════════════════════════════════════
             CUSTOM TITLE BAR
        ══════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Height="36"
                Background="{StaticResource TitleBarBrush}"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="0,0,0,1"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="SQL Data Compare"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Menu bar (center-left area) -->
                <Menu Grid.Column="1" VerticalAlignment="Center"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True"
                      Background="Transparent" BorderThickness="0"
                      Margin="16,0,0,0">
                    <MenuItem Header="_File"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              Background="Transparent">
                        <MenuItem Header="_New"      Command="{Binding NewProjectCommand}"/>
                        <MenuItem Header="_Open…"    Command="{Binding OpenProjectCommand}"/>
                        <MenuItem Header="_Save"     Command="{Binding SaveProjectCommand}"/>
                        <MenuItem Header="Save _As…" Command="{Binding SaveProjectAsCommand}"/>
                        <Separator/>
                        <MenuItem Header="E_xit" Click="Exit_Click"/>
                    </MenuItem>
                    <MenuItem Header="_Compare"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              Background="Transparent">
                        <MenuItem Header="_Run Compare"          Command="{Binding RunCompareCommand}" FontWeight="SemiBold"/>
                        <MenuItem Header="_Stop Compare"         Command="{Binding CancelCompareCommand}"/>
                        <Separator/>
                        <MenuItem Header="_Sync to Destination…" Command="{Binding SyncToDestinationCommand}"/>
                    </MenuItem>
                </Menu>

                <!-- Window chrome buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="─" Width="46" Height="36"
                            Click="MinimizeButton_Click"
                            FontSize="14" ToolTip="Minimize"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A3348"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="□" Width="46" Height="36"
                            Click="MaximizeButton_Click"
                            FontSize="13" ToolTip="Maximize / Restore"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A3348"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✕" Width="46" Height="36"
                            Click="CloseButton_Click"
                            FontSize="13" ToolTip="Close"
                            BorderThickness="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#8B2020"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════
             STATUS BAR
        ══════════════════════════════════════════════ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem HorizontalContentAlignment="Stretch"
                           Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=StatusBar}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="6,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="{Binding CompareTimingText}"
                               VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"
                               Margin="8,0,4,0" MinWidth="140" TextTrimming="CharacterEllipsis" FontSize="12"/>
                    <ProgressBar Grid.Column="2" Width="140" Height="10" Margin="4,2,8,2"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding CompareProgressPercent}"
                                 IsIndeterminate="{Binding CompareProgressIndeterminate}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </StatusBarItem>
        </StatusBar>

        <!-- ══════════════════════════════════════════════
             MAIN TAB AREA
        ══════════════════════════════════════════════ -->
        <TabControl Margin="0" SelectedIndex="{Binding MainTabIndex, Mode=TwoWay}">

            <!-- ═════ SETUP TAB ═════ -->
            <TabItem Header="Setup">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Background="{StaticResource PanelBrush}">
                    <Grid Margin="12,10,12,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: info banner + project fields -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <Border Background="{StaticResource DangerBgBrush}"
                                    BorderBrush="{StaticResource DangerFgBrush}"
                                    BorderThickness="0,0,0,0" CornerRadius="2"
                                    Padding="10,6" Margin="0,0,0,8">
                                <TextBlock TextWrapping="Wrap" FontSize="12">
                                    <Run FontWeight="SemiBold" Foreground="{StaticResource InfoFgBrush}">Source is read-only.</Run>
                                    <Run Foreground="{StaticResource TextSecondaryBrush}">Comparison only reads from the source. Nothing in this tool writes to or alters the source; sync applies changes on the destination only.</Run>
                                </TextBlock>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Project file" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Text="{Binding ProjectPath}" IsReadOnly="True"
                                         VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="3" Text="Project name" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="4"
                                         Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <!-- Row 1: Source | Destination -->
                        <Grid Grid.Row="1" Margin="0,0,0,0" MinHeight="280">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Source GroupBox -->
                            <GroupBox Grid.Column="0" Header="Source (read-only)" Padding="10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Endpoint kind" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                        <ComboBox ItemsSource="{Binding EndpointKinds}"
                                                  SelectedItem="{Binding SourceEndpoint.Kind}"
                                                  Margin="0,0,0,8"/>

                                        <!-- Database mode -->
                                        <StackPanel Margin="0,4,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SourceEndpoint.Kind}" Value="database">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Database provider" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding DatabaseProviders}"
                                                      SelectedItem="{Binding SourceEndpoint.Provider}"
                                                      Margin="0,0,0,8"/>
                                            <TextBlock Text="Connection string (use ${ENV:VAR} for secrets)"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding SourceEndpoint.ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True" Height="52" TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"/>
                                                <Button Grid.Column="1" Content="SQL connection…"
                                                        Command="{Binding BrowseSqlSourceCommand}"
                                                        Padding="10,4" Margin="8,0,0,0" VerticalAlignment="Top">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SourceEndpoint.Provider}" Value="sqlserver">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                            <TextBlock Text="Optional: schema filter (e.g. dbo or leave empty for all)"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding SourceEndpoint.SchemaIncludePattern, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8"/>
                                            <Button Content="Test connection" Command="{Binding TestSourceConnectionCommand}"
                                                    HorizontalAlignment="Left" Padding="12,5"/>
                                        </StackPanel>

                                        <!-- Folder mode -->
                                        <StackPanel Margin="0,4,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SourceEndpoint.Kind}" Value="insertFolder">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Folder with .sql INSERT files"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding SourceEndpoint.FolderRootPath, UpdateSourceTrigger=PropertyChanged}"
                                                         VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="Browse…"
                                                        Command="{Binding BrowseFolderSourceCommand}"
                                                        Padding="10,4" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="SQL dialect" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding SqlDialects}"
                                                      SelectedItem="{Binding SourceEndpoint.SqlDialect}"
                                                      Margin="0,0,0,8"/>
                                            <TextBlock Text="File naming pattern" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding SourceEndpoint.FileNaming, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8"/>
                                            <TextBlock Text="Search pattern" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding SourceEndpoint.SearchPattern, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8"/>
                                            <TextBlock Text="Default schema (MySQL database name, or leave empty for dbo/public)"
                                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding SourceEndpoint.DefaultSchema, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8"/>
                                            <Button Content="Test folder" Command="{Binding TestSourceConnectionCommand}"
                                                    HorizontalAlignment="Left" Padding="12,5"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </GroupBox>

                            <!-- Destination GroupBox -->
                            <GroupBox Grid.Column="2" Header="Destination" Padding="10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Endpoint kind" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                        <ComboBox ItemsSource="{Binding EndpointKinds}"
                                                  SelectedItem="{Binding DestEndpoint.Kind}"
                                                  Margin="0,0,0,8"/>

                                        <!-- Database mode -->
                                        <StackPanel Margin="0,4,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DestEndpoint.Kind}" Value="database">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Database provider" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding DatabaseProviders}"
                                                      SelectedItem="{Binding DestEndpoint.Provider}"
                                                      Margin="0,0,0,8"/>
                                            <TextBlock Text="Connection string" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding DestEndpoint.ConnectionString, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True" Height="52" TextWrapping="Wrap"
                                                         VerticalScrollBarVisibility="Auto"/>
                                                <Button Grid.Column="1" Content="SQL connection…"
                                                        Command="{Binding BrowseSqlDestinationCommand}"
                                                        Padding="10,4" Margin="8,0,0,0" VerticalAlignment="Top">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DestEndpoint.Provider}" Value="sqlserver">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                            <TextBlock Text="Optional schema filter" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding DestEndpoint.SchemaIncludePattern, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8"/>
                                            <Button Content="Test connection" Command="{Binding TestDestinationConnectionCommand}"
                                                    HorizontalAlignment="Left" Padding="12,5"/>
                                        </StackPanel>

                                        <!-- Folder mode -->
                                        <StackPanel Margin="0,4,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DestEndpoint.Kind}" Value="insertFolder">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="Folder root" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding DestEndpoint.FolderRootPath, UpdateSourceTrigger=PropertyChanged}"
                                                         VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="Browse…"
                                                        Command="{Binding BrowseFolderDestinationCommand}"
                                                        Padding="10,4" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="SQL dialect" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <ComboBox ItemsSource="{Binding SqlDialects}"
                                                      SelectedItem="{Binding DestEndpoint.SqlDialect}"
                                                      Margin="0,0,0,8"/>
                                            <TextBlock Text="File naming pattern" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding DestEndpoint.FileNaming, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8"/>
                                            <TextBlock Text="Search pattern" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding DestEndpoint.SearchPattern, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8"/>
                                            <TextBlock Text="Default schema" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding DestEndpoint.DefaultSchema, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8"/>
                                            <Button Content="Test folder" Command="{Binding TestDestinationConnectionCommand}"
                                                    HorizontalAlignment="Left" Padding="12,5"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </GroupBox>
                        </Grid>

                        <!-- Row 2: Compare Options | Tables to compare -->
                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <GroupBox Grid.Column="0" Header="Compare options" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <CheckBox Grid.Row="0" Grid.ColumnSpan="2"
                                              Content="Ordinal ignore case (recommended)"
                                              IsChecked="{Binding OrdinalIgnoreCase}"
                                              Margin="0,0,0,8"/>
                                    <CheckBox Grid.Row="1" Grid.ColumnSpan="2"
                                              Content="Skip binary / image columns in compare (faster for blob tables; keys still compared)"
                                              IsChecked="{Binding SkipBinaryColumnsInCompare}"
                                              Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Max reported diffs / table"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,12,6"/>
                                    <TextBox Grid.Row="2" Grid.Column="1"
                                             Text="{Binding MaxReportedDiffsPerTable}" Margin="0,0,0,6"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="Command timeout (seconds)"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1"
                                             Text="{Binding CommandTimeoutSeconds}"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Grid.Column="2" Header="Tables to compare" Padding="10">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,0,6" FontSize="12">
                                        Leave empty to compare every table on the source. Destination schema/table is optional.
                                        Use Skip to exclude a listed table without removing the row.
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Button Content="Add row" Command="{Binding AddTableRowCommand}"
                                                Padding="10,4" Margin="0,0,8,0"/>
                                        <Button Content="Remove selected" Command="{Binding RemoveTableRowCommand}"
                                                Padding="10,4" Margin="0,0,8,0"/>
                                        <Button Content="Discover from source" Command="{Binding DiscoverSourceTablesCommand}"
                                                Padding="10,4"/>
                                    </StackPanel>
                                    <DataGrid ItemsSource="{Binding TableRows}"
                                              SelectedItem="{Binding SelectedTableRow}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              MinHeight="160"
                                              HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Header="Skip"
                                                                    Binding="{Binding SkipCompare, UpdateSourceTrigger=PropertyChanged}"
                                                                    Width="52"/>
                                            <DataGridTextColumn Header="Source schema"
                                                                Binding="{Binding SourceSchema, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*"/>
                                            <DataGridTextColumn Header="Source table"
                                                                Binding="{Binding SourceTable, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*"/>
                                            <DataGridTextColumn Header="Dest schema (optional)"
                                                                Binding="{Binding DestSchema, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*"/>
                                            <DataGridTextColumn Header="Dest table (optional)"
                                                                Binding="{Binding DestTable, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ═════ RESULTS TAB ═════ -->
            <TabItem Header="Results">
                <Grid Background="{StaticResource PanelBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- filter / action bar -->
                        <RowDefinition Height="Auto"/>  <!-- sync selection buttons -->
                        <RowDefinition Height="Auto"/>  <!-- progress panels -->
                        <RowDefinition Height="*"/>     <!-- main content grids -->
                        <RowDefinition Height="Auto"/>  <!-- bottom nav bar -->
                        <RowDefinition Height="Auto"/>  <!-- sync options -->
                    </Grid.RowDefinitions>

                    <!-- ── Filter / action bar ── -->
                    <Border Grid.Row="0"
                            Background="{StaticResource PanelHeaderBrush}"
                            BorderBrush="{StaticResource SeparatorBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Show:"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding TableFilterPresetOptions}"
                                      SelectedItem="{Binding TableFilterPreset}"
                                      Width="160" VerticalAlignment="Center"/>
                            <!-- Summary text -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DifferenceSummaryText}"
                                       Foreground="{StaticResource WarningFgBrush}"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            <!-- Sync button -->
                            <Button Grid.Column="4"
                                    Content="Sync to Destination…"
                                    Command="{Binding SyncToDestinationCommand}"
                                    Padding="14,5" FontWeight="SemiBold">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#2A4A70" Offset="0"/>
                                                    <GradientStop Color="#1E3A58" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ── Sync selection buttons ── -->
                    <Border Grid.Row="1"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource SeparatorBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,5">
                        <WrapPanel>
                            <TextBlock Text="Tables:" VerticalAlignment="Center"
                                       Margin="0,2,8,2" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            <Button Content="Select all" Command="{Binding SelectAllTablesForSyncCommand}" Padding="8,3" Margin="0,2,6,2" FontSize="12"/>
                            <Button Content="Clear" Command="{Binding ClearTablesForSyncCommand}" Padding="8,3" Margin="0,2,6,2" FontSize="12"/>
                            <Button Content="Sync ON — selected" Command="{Binding SetSyncOnSelectedTablesCommand}" Padding="8,3" Margin="0,2,6,2" FontSize="12"
                                    ToolTip="Ctrl+click or Shift+click to select multiple table rows, then turn Sync on."/>
                            <Button Content="Sync OFF — selected" Command="{Binding ClearSyncOnSelectedTablesCommand}" Padding="8,3" Margin="0,2,14,2" FontSize="12"
                                    ToolTip="Clear the Sync checkbox only for the selected rows."/>
                            <TextBlock Text="Rows:" VerticalAlignment="Center"
                                       Margin="0,2,8,2" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            <Button Content="Select all" Command="{Binding SelectAllRowDiffsCommand}" Padding="8,3" Margin="0,2,6,2" FontSize="12"/>
                            <Button Content="Clear" Command="{Binding ClearRowDiffsCommand}" Padding="8,3" Margin="0,2,6,2" FontSize="12"/>
                            <Button Content="Sync ON — selected" Command="{Binding SetSyncOnSelectedRowDiffsCommand}" Padding="8,3" Margin="0,2,6,2" FontSize="12"
                                    ToolTip="Ctrl+click or Shift+click multiple rows, then turn Sync on."/>
                            <Button Content="Sync OFF — selected" Command="{Binding ClearSyncOnSelectedRowDiffsCommand}" Padding="8,3" Margin="0,2,0,2" FontSize="12"
                                    ToolTip="Clear Sync checkbox for selected differing rows."/>
                        </WrapPanel>
                    </Border>

                    <!-- ── Progress panels ── -->
                    <StackPanel Grid.Row="2">
                        <!-- Compare progress -->
                        <Border Visibility="{Binding IsComparing, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{StaticResource SuccessBgBrush}"
                                BorderBrush="{StaticResource SuccessFgBrush}"
                                BorderThickness="0,2,0,0"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="Compare in progress" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource SuccessFgBrush}" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{StaticResource PanelHeaderBrush}"
                                        CornerRadius="3" Padding="10,5" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProgressTablesText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ProgressTablesText}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource SuccessFgBrush}"/>
                                </Border>
                                <Border Grid.Column="2" Background="{StaticResource PanelHeaderBrush}"
                                        CornerRadius="3" Padding="10,5" Margin="0,0,16,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProgressRowsText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ProgressRowsText}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource SuccessFgBrush}"/>
                                </Border>
                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <ProgressBar Height="16" Minimum="0" Maximum="100"
                                                 Value="{Binding CompareProgressPercent}"
                                                 IsIndeterminate="{Binding CompareProgressIndeterminate}"
                                                 Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CompareTimingText}" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Sync progress -->
                        <Border Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="{StaticResource PanelHeaderBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="0,2,0,0"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="Sync in progress" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource InfoFgBrush}" Margin="0,0,0,3"/>
                                    <TextBlock Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{StaticResource PanelBrush}"
                                        CornerRadius="3" Padding="10,5" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProgressTablesText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ProgressTablesText}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource InfoFgBrush}"/>
                                </Border>
                                <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                                        CornerRadius="3" Padding="10,5" Margin="0,0,16,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProgressRowsText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ProgressRowsText}" FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource InfoFgBrush}"/>
                                </Border>
                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                    <ProgressBar Height="16" Minimum="0" Maximum="100"
                                                 Value="{Binding CompareProgressPercent}"
                                                 IsIndeterminate="{Binding CompareProgressIndeterminate}"
                                                 Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CompareTimingText}" FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ── Main content: table list | row diffs ── -->
                    <Grid Grid.Row="3" Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Compare results (table list) -->
                        <DockPanel Grid.Column="0" Background="{StaticResource PanelBrush}">
                            <!-- Panel header -->
                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource PanelHeaderBrush}"
                                    BorderBrush="{StaticResource SeparatorBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="10,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Table Differences"
                                               FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBox Grid.Column="2"
                                             Text="{Binding TableFilterText, UpdateSourceTrigger=PropertyChanged}"
                                             Width="120" VerticalAlignment="Center" Margin="0,0,8,0"
                                             ToolTip="Search source, destination, status, note, or counts"/>
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding TableFilterPresetOptions}"
                                              SelectedItem="{Binding TableFilterPreset}"
                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Button Grid.Column="4" Content="↺" Command="{Binding ClearTableFiltersCommand}"
                                            Padding="6,3" VerticalAlignment="Center" FontSize="14"
                                            ToolTip="Reset filters"/>
                                </Grid>
                            </Border>

                            <!-- Table list DataGrid -->
                            <DataGrid ItemsSource="{Binding FilteredResultRows}"
                                      SelectedItem="{Binding SelectedCompareResult, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      IsReadOnly="False"
                                      SelectionChanged="CompareResultsGrid_OnSelectionChanged">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Different">
                                                <Setter Property="Background" Value="{StaticResource RowChangeBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="SampledDifferent">
                                                <Setter Property="Background" Value="{StaticResource RowChangeBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Error">
                                                <Setter Property="Background" Value="{StaticResource RowDeleteBrush}"/>
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource GridSelectBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Sync" Width="46">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IncludeInSync, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Source"      Binding="{Binding Source}"      Width="*"   IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Dest"        Binding="{Binding Destination}" Width="*"   IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Status"      Binding="{Binding Status}"      Width="90"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="+Src"        Binding="{Binding OnlySource}"  Width="48"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="+Dst"        Binding="{Binding OnlyDestination}" Width="48" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Val Δ"       Binding="{Binding ValueDiffs}"  Width="48"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="↑Ins"        Binding="{Binding SyncInserted}" Width="44" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="~Upd"        Binding="{Binding SyncUpdated}"  Width="44" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="-Del"        Binding="{Binding SyncDeleted}"  Width="44" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Note"        Binding="{Binding Note}"         Width="2*" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>

                        <!-- Vertical separator -->
                        <Border Grid.Column="1" Background="{StaticResource SeparatorBrush}"/>

                        <!-- Right: Differing rows -->
                        <DockPanel Grid.Column="2" Background="{StaticResource PanelBrush}">
                            <!-- Panel header -->
                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource PanelHeaderBrush}"
                                    BorderBrush="{StaticResource SeparatorBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="10,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Row Differences"
                                               FontWeight="SemiBold" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBox Grid.Column="2"
                                             Text="{Binding RowDiffFilterText, UpdateSourceTrigger=PropertyChanged}"
                                             Width="100" VerticalAlignment="Center" Margin="0,0,8,0"
                                             ToolTip="Search kind, key, or column details"/>
                                    <ComboBox Grid.Column="3"
                                              ItemsSource="{Binding RowDiffKindPresetOptions}"
                                              SelectedItem="{Binding RowDiffKindPreset}"
                                              VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Button Grid.Column="4" Content="↺" Command="{Binding ClearRowDiffFiltersCommand}"
                                            Padding="6,3" VerticalAlignment="Center" FontSize="14"
                                            ToolTip="Reset filters"/>
                                </Grid>
                            </Border>

                            <!-- Hint text -->
                            <TextBlock DockPanel.Dock="Top"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="10,4,10,2" FontSize="11">
                                Select a table on the left. Each row shows the change kind and key; value-changed rows list
                                <Run FontWeight="SemiBold">every differing column</Run> with source vs destination (green/red tint).
                                A text summary is in the “Column differences” column. Scroll within a row if many columns.
                            </TextBlock>

                            <!-- Warning: counts but no rows -->
                            <TextBlock DockPanel.Dock="Bottom" Margin="10,6,10,6"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource WarningFgBrush}" FontSize="12"
                                       Visibility="{Binding SelectedCompareResult.HasCountsButNoRowSample, Converter={StaticResource BoolToVisibilityConverter}}">
                                Counts show differences but no sample rows are in this list. Increase
                                <Run FontWeight="SemiBold">Max reported diffs / table</Run>
                                on the Setup tab and run compare again.
                            </TextBlock>

                            <!-- Row diff DataGrid -->
                            <DataGrid ItemsSource="{Binding RowDiffsView}"
                                      SelectedItem="{Binding SelectedRowDiff, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      IsReadOnly="False"
                                      EnableRowVirtualization="False"
                                      RowDetailsVisibilityMode="Visible"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      SelectionChanged="RowDiffsGrid_OnSelectionChanged">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="MissingInDestination">
                                                <Setter Property="Background" Value="{StaticResource RowInsertBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="MissingInSource">
                                                <Setter Property="Background" Value="{StaticResource RowDeleteBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="ValueMismatch">
                                                <Setter Property="Background" Value="{StaticResource RowChangeBrush}"/>
                                            </DataTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource GridSelectBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.RowDetailsTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource PanelHeaderBrush}"
                                                BorderBrush="{StaticResource SeparatorBrush}"
                                                BorderThickness="0,1,0,1"
                                                Padding="10,8" Margin="0">
                                            <StackPanel>
                                                <TextBlock Text="Column-level values (source vs destination)"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,6"/>
                                                <DataGrid AutoGenerateColumns="False" HeadersVisibility="Column"
                                                          IsReadOnly="True" CanUserAddRows="False"
                                                          EnableRowVirtualization="False"
                                                          MaxHeight="280" GridLinesVisibility="Horizontal">
                                                    <DataGrid.Style>
                                                        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ColumnDiffs.Count}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </DataGrid.Style>
                                                    <DataGrid.ItemsSource>
                                                        <Binding Path="ColumnDiffs"/>
                                                    </DataGrid.ItemsSource>
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Column" Binding="{Binding ColumnName}" Width="*" MinWidth="100" IsReadOnly="True">
                                                            <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Padding" Value="4,3"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                </Style>
                                                            </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                        <DataGridTextColumn Header="Source" Binding="{Binding SourceValue}" Width="2*" MinWidth="120" IsReadOnly="True">
                                                            <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Padding" Value="4,3"/>
                                                                    <Setter Property="Background" Value="{StaticResource DiffSourceCellBgBrush}"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                                </Style>
                                                            </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                        <DataGridTextColumn Header="Destination" Binding="{Binding DestinationValue}" Width="2*" MinWidth="120" IsReadOnly="True">
                                                            <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Padding" Value="4,3"/>
                                                                    <Setter Property="Background" Value="{StaticResource DiffDestCellBgBrush}"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                                </Style>
                                                            </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                                <TextBlock TextWrapping="Wrap" FontStyle="Italic"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           Margin="0,6,0,0" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ColumnDiffs.Count}" Value="0">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    No per-column breakdown for this row (e.g. insert-missing or delete-extra).
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGrid.RowDetailsTemplate>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="28">
                                        <DataGridTemplateColumn.Header>
                                            <TextBlock Text="±" Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </DataGridTemplateColumn.Header>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ChangeIndicatorLabel}"
                                                           FontWeight="Bold" FontSize="13"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Kind}" Value="MissingInDestination">
                                                                    <Setter Property="Foreground" Value="{StaticResource SuccessFgBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="MissingInSource">
                                                                    <Setter Property="Foreground" Value="{StaticResource DangerFgBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Kind}" Value="ValueMismatch">
                                                                    <Setter Property="Foreground" Value="{StaticResource WarningFgBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Sync" Width="46">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IncludeInSync, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Kind"   Binding="{Binding KindLabel}"  Width="160" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Key"    Binding="{Binding KeyDisplay}" Width="120" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="Column differences (summary)" Width="2*" MinWidth="200">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Detail}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           FontSize="12"
                                                           Padding="0,2"
                                                           MaxHeight="120"
                                                           VerticalAlignment="Top">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Detail}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>

                    <!-- ── Bottom navigation bar ── -->
                    <Border Grid.Row="4"
                            Background="{StaticResource PanelHeaderBrush}"
                            BorderBrush="{StaticResource SeparatorBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="10,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="← Previous Difference"
                                    Command="{Binding PreviousDifferenceCommand}"
                                    HorizontalAlignment="Left" Padding="10,4"/>
                            <!-- Position indicator -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentPositionText}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="13" VerticalAlignment="Center" MinWidth="80"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Next Difference →"
                                    Command="{Binding NextDifferenceCommand}"
                                    HorizontalAlignment="Right" Padding="10,4"/>
                        </Grid>
                    </Border>

                    <!-- ── Sync options ── -->
                    <Border Grid.Row="5"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource SeparatorBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Sync options:" VerticalAlignment="Center"
                                       Margin="0,0,10,0" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                            <CheckBox Content="Insert missing"
                                      IsChecked="{Binding SyncInsertMissing}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <CheckBox Content="Update changed"
                                      IsChecked="{Binding SyncUpdateChanged}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <CheckBox Content="Delete extra (destructive)"
                                      IsChecked="{Binding SyncDeleteExtra}"
                                      VerticalAlignment="Center" Margin="0,0,12,0"
                                      Foreground="{StaticResource DangerFgBrush}"/>
                            <CheckBox Content="Disable FK checks"
                                      IsChecked="{Binding SyncDisableForeignKeyChecks}"
                                      VerticalAlignment="Center" Margin="0,0,16,0"
                                      Foreground="{StaticResource WarningFgBrush}"
                                      ToolTip="Suppresses foreign-key constraint checks during sync. Use when tables have circular FK references or when topological ordering is insufficient."/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
